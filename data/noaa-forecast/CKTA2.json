 primary tidal bench mark, referenced to the International Great Lakes Datum of 1985 (IGLD 85) local mean sea level height value, at Father Point, Rimouski, Quebec, Canada was held fixed, thus providing minimum constraint. NAVD 88 and IGLD 85 are identical. However, NAVD 88 bench mark values are given in Helmert orthometric height units while IGLD 85 values are in dynamic heights. See International Great Lakes Datum of 1985, National Geodetic Vertical Datum of 1929, and geopotential difference. NAVD 88 should not be used as Mean Sea Level.","value":0}]},"horizontal":{"value":[]},"notes":{"value":[]}},"inundation":{"enabled":false,"url":"","zeroDatum":null,"downloads":null,"siteSpecificInfo":"","dataAttribution":[]},"upstreamLid":"","downstreamLid":"","inService":{"enabled":false,"message":"Gage is currently out of service."},"lowThreshold":null,"forecastReliability":"Forecasts are issued routinely during the warm season, and as needed at other times of the year.","TruncateObs":"-1","TruncateFcst":"-1","ObservedFloodCategory":"out_of_service","ForecastFloodCategory":"out_of_service"},"stageflow":{"observed":{"pedts":"HGIRZ","issuedTime":"0001-01-01T00:00:00Z","wfo":"AJK","timeZone":"AST9ADT","primaryName":"Stage","primaryUnits":"ft","secondaryName":"Flow","secondaryUnits":"kcfs","data":[]},"forecast":{"pedts":"HGIFE","issuedTime":"0001-01-01T00:00:00Z","wfo":"AJK","timeZone":"AST9ADT","primaryName":"Stage","primaryUnits":"ft","secondaryName":"Flow","secondaryUnits":"kcfs","data":[]}},"modelGuidance":{},"availableSeries":[],"generatedAt":"2026-05-01T12:13:54.487Z"}