{"gauge":{"lid":"WMPG1","usgsId":"02191740","reachId":"6279141","name":"Cloud Creek near Watson Mill Park","description":"","rfc":{"abbreviation":"SERFC","name":"Southeast River Forecast Center"},"wfo":{"abbreviation":"FFC","name":"Peachtree City"},"state":{"abbreviation":"GA","name":"Georgia"},"county":"Oglethorpe","timeZone":"EST5EDT","latitude":34.020555555556,"longitude":-83.069444444444,"pedts":{"observed":"HGIRG","forecast":""},"status":{"observed":{"primary":-999,"primaryUnit":"","secondary":-999,"secondaryUnit":"","floodCategory":"out_of_service","validTime":"0001-01-01T00:00:00Z"},"forecast":{"primary":-999,"primaryUnit":"","secondary":-999,"secondaryUnit":"","floodCategory":"out_of_service","validTime":"0001-01-01T00:00:00Z"}},"flood":{"stageUnits":"ft","flowUnits":"cfs","categories":{"major":{"stage":-9999,"flow":-9999},"moderate":{"stage":41,"flow":-9999},"minor":{"stage":38,"flow":-9999},"action":{"stage":36,"flow":-9999}},"lro":null,"crests":{"historic":[{"occurredTime":"2015-12-31T03:45:00Z","stage":42.71,"flow":0,"preliminary":"O","olddatum":false}],"recent":[{"occurredTime":"2015-12-31T03:45:00Z","stage":42.71,"flow":0,"preliminary":"O","olddatum":false}]},"lowWaters":{"historic":[]},"impacts":[{"stage":42,"statement":"Significant flooding expands in the woodlands and pasture upstream and downstream from the gage near Whitsel Hollow Road. Flood waters will be around 4 feet deep in a picnic area and a EPA monitoring station on the upstream and left bank from the old wooden bridge. The water level will be around one foot deep impacting a generator to the EPA structure and the USGS gage house. A transmission data loss will be likely. Large portions of the Watson Mill Bridge State Park near the creek will be flooded."},{"stage":41,"statement":"Moderate flooding begins. Significant flooding occurs in the woodlands and pasture upstream and downstream along the creek from the gage near Whitsel Hollow Road. Flood waters will be around 3 feet deep in a picnic area and a EPA monitoring station on the upstream and left bank from the old wooden bridge. The water level reaches the bottom of a generator to the EPA structure and the bottom of the USGS gage house. Large portions of the Watson Mill Bridge State Park near the creek will be flooded."},{"stage":40,"statement":"Minor flooding continues to expand in the woodlands and pasture upstream and downstream along the creek from the gage near Whitsel Hollow Road. Flood waters will be around two feet deep in a picnic area and a EPA monitoring station on the upstream and left bank from the old wooden bridge. Portions of the Watson Mill Bridge State Park near the creek will be flooded."},{"stage":38,"statement":"Flood stage is reached. Minor flooding begins in the woodlands and pasture upstream and downstream along the creek from the gage near Whitsel Hollow Road. The water begins to flood a picnic area and a EPA monitoring station on the upstream and left bank from the old wooden bridge. Portions of the Watson Mill Bridge State Park near the creek will begin to flood."},{"stage":36,"statement":"Bankfull conditions are reached upstream and downstream along the creek from the gage near Whitsel Hollow Road. The water reaches the wood deck of an EPA monitoring station on the upstream and left bank from the old wooden bridge. Low lying areas of the Watson Mill Bridge State Park near the creek will begin to flood. "}]},"images":{"probability":{"weekint":{"stage":"","flow":"","volume":""},"entperiod":{"stage":"","flow":"","volume":""},"shortrange":""},"hydrograph":{"default":"https://water.noaa.gov/resources/hydrographs/wmpg1_hg.png","floodcat":"https://water.noaa.gov/resources/hydrographs/wmpg1_record.png"},"photos":[]},"dataAttribution":[{"abbrev":"US Geological Survey","text":"USGS--Water Resources of the United States","title":"US Geological Survey","url":"https://waterdata.usgs.gov/nwis"},{"abbrev":"USGS","text":"02191740","title":"Observations courtesy of U.S. Geological Survey