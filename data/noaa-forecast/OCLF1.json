ric":[]},"impacts":[{"stage":30,"statement":"Record flooding throughout the Lower Ochlockonee River Basin. In Wakulla County, Smith Creek Road floods at numerous locations south of Jack Langston Road. In Liberty County, access to areas along CR-22 is impossible as the road is flooded more than 1 mile west of the river. "},{"stage":26,"statement":"Major and catastrophic flooding throughout the Lower Ochlockonee River Basin. In Wakulla County, water affects several residences along Easy Street North near the boat landing. The Smith Creek Road bridge south of Forest Road 13 over Smith Creek floods at this level. In Liberty County, flooding expands significantly at CR-22. Many residences are flooded at this level. "},{"stage":24,"statement":"In Wakulla County, all areas south of Jack Langston Road on Easy Street South experience significant flooding. Water reaches the base of the bridges over the Ochlockonee River on the Wakulla County side of Forest Road 13. Water reaches the base of the bridge over Smith Creek on Smith Creek Road south of Forest Road 13. In Liberty County, water crosses CR-67 in several places near and south of Forest Road 125. Flooding along CR-22 worsens, affecting more residences.  "},{"stage":22,"statement":"In Wakulla County, flooding worsens along Easy Street South, as all structures not elevated experience significant flooding. In Liberty County, a couple of residences are prone to flooding at the end of CR-22. "},{"stage":21,"statement":"In Wakulla County, all homes not elevated on Easy Street South are isolated or flooded at this level. Structures just north of the Jack Langston Boat Ramp are prone to flooding above this level. In Liberty County, CR-67 begins to flood near the turnoff to the Hitchock Lake Camp Ground. Water comes over the riverbank at CR-22 in Liberty County. "},{"stage":20,"statement":"In Wakulla COunty, most residences on Easy Street South are surrounded by water or if not elevated, are flooded. The Jack Langston Boat Ramp is in accessible above this level. "},{"stage":19,"statement":"In Wakulla County, water impacts more homes on Easy Street South. Water comes over the bank at the Jack Langston Boat Ramp. In Liberty County, Forest Road 13 floods at this level west of the main bridge. "},{"stage":18,"statement":"In Wakulla County, most of Easy Street South is flooded. Water begins to encroach on residences at the end of the road. "},{"stage":17,"statement":"Easy Street South floods about one quarter mile south of Jack Langston Road, extending to the south end of the road. "},{"stage":16.5,"statement":"Water begins to cross the southermost portion of Easy Street South in Wakulla County. "}]},"images":{"probability":{"weekint":{"stage":"https://water.noaa.gov/resources/probabilistic/exceedance/OCLF1.SSTG.prob.weekint.gif","flow":"https://water.noaa.gov/resources/probabilistic/exceedance/OCLF1.QINE.prob.weekint.gif","volume":"https://water.noaa.gov/resources/probabilistic/exceedance/OCLF1.volume.prob.weekint.gif"},"entperiod":{"stage":"https://water.noaa.gov/resources/probabilistic/exceedance/OCLF1.SSTG.exceed.90day.gif","flow":"https://water.noaa.gov/resources/probabilistic/exceedance/OCLF1.QINE.exceed.90day.gif","volume":"https://water.noaa.gov/resources/probabilistic/exceedance/OCLF1.volume.exceed.90day.gif"},"shortrange":""},"hydrograph":{"default":"https://water.noaa.gov/resources/hydrographs/oclf1_hg.png","floodcat":"https://water.noaa.gov/resources/hydrographs/oclf1_record.png"},"photos":[]},"dataAttribution":[{"abbrev":"US Geological Survey","text":"USGS--Water Resources of the United States","title":"US Geological Survey","url":"https://waterdata.usgs.gov/nwis"},{"abbrev":"USGS","text":"02330150","title":"Observations courtesy of U.S. Geological Survey","url":"https://waterdata.usgs.gov/nwis/inventory/?site_no=02330150"}],"impactsLowWaters":[],"normalThreshold":{"value":0,"units":"ft"},"hydronotes":[],"datums":{"vertical":{"value":[{"label":"National Geodetic Vertical Datum of 1929","abbrev":"NGVD29","description":"A fixed reference adopted as a standard geodetic datum for elevations determined by leveling. The datum was derived for surveys from a general adjustment of the first-order leveling nets of both the United States and Canada. In the adjustment, mean sea level was held fixed as observed at 21 tide stations in the United States and 5 in Canada. The year indicates the time of the general adjustment. A synonym for Sea-level Datum of 1929. The geodetic datum is fixed and does not take into account the changing stands of sea level. Because there are many variables affecting sea level, and because the geodetic datum represents a best fit over a broad area, the relationship between the geodetic datum and local mean sea level is not consistent from one location to another in either time or space. For this reason, the National Geodetic Vertical Datum should not be confused with mean sea level. See North American Vertical Datum of 1988 (NAVD 88). NGVD 29 should not be used as Mean Sea Level. NGVD 29 is no longer supported by NGS.","value":3.25}]},"horizontal":{"value":[]},"notes":{"value":[]}},"inundation":{"enabled":false,"url":"","zeroDatum":null,"downloads":null,"siteSpecificInfo":"","dataAttribution":[]},"upstreamLid":"BLXF1","downstreamLid":"CTMF1","inService":{"enabled":false,"message":"Gage is currently out of service."},"lowThreshold":{"units":"ft","value":7.5},"forecastReliability":"Forecasts are not available. Only observed stages are available for this point.","TruncateObs":"-1","TruncateFcst":"0","ObservedFloodCategory":"out_of_service","ForecastFloodCategory":"out_of_service"},"stageflow":{"observed":{"pedts":"","issuedTime":"0001-01-01T00:00:00Z","wfo":"","timeZone":"","primaryName":"","primaryUnits":"","secondaryName":"","secondaryUnits":"","data":[]},"forecast":{"pedts":"","issuedTime":"0001-01-01T00:00:00Z","wfo":"","timeZone":"","primaryName":"","primaryUnits":"","secondaryName":"","secondaryUnits":"","data":[]}},"modelGui