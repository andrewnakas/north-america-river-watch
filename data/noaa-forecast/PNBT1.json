{"gauge":{"lid":"PNBT1","usgsId":"03430320","reachId":"18408580","name":"Cumberland River near Penington Bend","description":"","rfc":{"abbreviation":"OHRFC","name":"Ohio River Forecast Center"},"wfo":{"abbreviation":"OHX","name":"Old Hickory"},"state":{"abbreviation":"TN","name":"Tennessee"},"county":"Davidson","timeZone":"CST6CDT","latitude":36.235277777778,"longitude":-86.7125,"pedts":{"observed":"HGIRG","forecast":"HGIFF"},"status":{"observed":{"primary":-999,"primaryUnit":"","secondary":-999,"secondaryUnit":"","floodCategory":"obs_not_current","validTime":"0001-01-01T00:00:00Z"},"forecast":{"primary":-999,"primaryUnit":"","secondary":-999,"secondaryUnit":"","floodCategory":"fcst_not_current","validTime":"0001-01-01T00:00:00Z"}},"flood":{"stageUnits":"ft","flowUnits":"cfs","categories":{"major":{"stage":55,"flow":-9999},"moderate":{"stage":51,"flow":-9999},"minor":{"stage":47,"flow":-9999},"action":{"stage":42,"flow":-9999}},"lro":null,"crests":{"historic":[{"occurredTime":"2019-02-24T06:30:00Z","stage":48.83,"flow":0,"preliminary":"O","olddatum":false},{"occurredTime":"2013-04-29T00:00:00Z","stage":40.33,"flow":0,"preliminary":"O","olddatum":false},{"occurredTime":"2016-02-18T00:00:00Z","stage":38.57,"flow":0,"preliminary":"O","olddatum":false},{"occurredTime":"2011-04-18T00:00:00Z","stage":36.99,"flow":0,"preliminary":"O","olddatum":false},{"occurredTime":"2012-03-09T00:00:00Z","stage":36.33,"flow":0,"preliminary":"O","olddatum":false},{"occurredTime":"2014-02-05T00:00:00Z","stage":35.19,"flow":0,"preliminary":"O","olddatum":false}],"recent":[{"occurredTime":"2019-02-24T06:30:00Z","stage":48.83,"flow":0,"preliminary":"O","olddatum":false},{"occurredTime":"2016-02-18T00:00:00Z","stage":38.57,"flow":0,"preliminary":"O","olddatum":false},{"occurredTime":"2014-02-05T00:00:00Z","stage":35.19,"flow":0,"preliminary":"O","olddatum":false},{"occurredTime":"2013-04-29T00:00:00Z","stage":40.33,"flow":0,"preliminary":"O","olddatum":false},{"occurredTime":"2012-03-09T00:00:00Z","stage":36.33,"flow":0,"preliminary":"O","olddatum":false},{"occurredTime":"2011-04-18T00:00:00Z","stage":36.99,"flow":0,"preliminary":"O","olddatum":false}]},"lowWaters":{"historic":[]},"impacts":[{"stage":61,"statement":"Much of the Pennington Bend area along the river is flooded, including Opryland, Opry Mills, Briley Pkwy between Mc Gavock Pike and Two Rivers Pkwy, the River Trace and River Glen subdivisions, homes and properties along and near Berwick Trail, Pennington Bend Rd, Music Valley Dr, Mc Gavock Pike, Miami Ave, areas of Madison near Idlewild Dr, Covington Place, the Montague area, and locations in Inglewood near the river."},{"stage":59,"statement":"The Opryland and Opry Mills area is under several feet of water, with flooding reaching portions of Briley Pkwy. Widespread flooding continues to impact the River Trace and River Glen subdivisions, homes and properties along and near Berwick Trail, Pennington Bend Rd, Music Valley Dr, Covington Place, the Montague area, and locations in Inglewood east of Stratford Ave near the river."},{"stage":57,"statement":"Water is at the top of the levee protecting Opryland and Opry Mills, and may be overtopping in some areas. Homes and properties in the River Trace and River Glen subdivisions, along and near Berwick Trail, Pennington Bend Rd, Mc Gavock Pike, Music Valley Dr, and Miami Ave are severely impacted. Extensive flooding is also impacting locations in Madison near Idlewild Dr, Covington Place, and the Montague Area, as well as locations in Inglewood east of Stratford Ave near the river."},{"stage":56,"statement":"Water approaches the top of the levee protecting the Opryland and Opry Mills area."},{"stage":55,"statement":"Extensive flooding is occurring in the River Trace and River Glen subdivisions, at homes and properties along and near Berwick Trail, Pennington Bend Rd, Mc Gavock Pike, and Miami Ave. Locations in Madison near Idlewild Dr, Covington Place, the Montague area, the Inglewood neighboorhood east of Stratford Ave near the river, and portions of Opryland and Opry Mills not protected by the levee are flooding. Water approaches homes on Canton Pass, Allen Pass, and Peeler Trail."},{"stage":53,"statement":"Locations near Berwick Trail, Cain Harbor Dr, Center St, Denson Ave, Emmitt Ave, Frost St, Idlewild Dr and Ct, Longfellow Dr, Madison Blvd, Mc Ginnis Dr, Miami Dr, Morgan Meade Dr and Ct, Moss Rose Dr and Ct, Music Valley Dr, Pennington Bend Rd, Penn Meade Way, River Bend Dr, River Meade Way, Yale Ave, and unprotected areas of Opryland and Opry Mills are flooded. Water approaches properties at Mc Gavock Pike and Pennington Bend Rd, and Lock Two Rd may be restricted at higher levels."},{"stage":51,"statement":"Areas near Berwick Trail, Center St, Denson Ave, Yale Ave, Madison Blvd, Idlewild Dr, Idlewild Ct, Emmitt Ave, Cain Harbor Dr, River Bend Dr, Frost St, Longfellow Dr, and Mc Ginnis Dr are flooded and access may be limited. Campgrounds near Music Valley Dr and Pennington Bend Rd are flooded, as well as portions of Opryland and Opry Mills not protected by the levee. Water also begins to impact homes on Morgan Meade Dr, Morgan Meade Ct, Moss Rose Ct, and Miami Ave."},{"stage":49,"statement":"Flooding continues on Berwick Trail, Denson Ave, Yale Ave, Madison Blvd, Idlewild Dr, properties in River Glen on Penn Meade Way and River Meade Way, and properties in River Trace on River Bend Dr, Cain Harbor Dr, and Longfellow Dr. Wooddale Ln is flooded and water approaches homes on Miami Ave and Pennington Bend Rd. Campgrounds near Music Valley Dr and Pennington Bend Rd are flooded, as well as portions of Opryland near Mc Gavock Pike and other areas of Opry Mills not protected by the levee."},{"stage":47,"statement":"Flooding is occurring along the river around Pennington Bend from near River Trace to the Cumberland River Greenway Bridge in Shelby Bottoms Park. Properties on Berwick Trail, areas near Gibson Creek on Denson Ave and Yale Ave, portions of Opryland near Mc Gavock Pike, properties in River Glen on Penn Meade Way, and properties in River Trace on River Bend Dr. Water approaches residential property on Pennington Bend Rd and Wooddale Ln, and campgrounds near Music Valley Dr and Pennington Bend Rd."},{"stage":44,"statement":"Water continues to inundate low lying areas along the river, including properties on Berwick Trail, areas near Gibson Creek on Denson Ave and Yale Ave, portions of Opryland near Mc Gavock Pike, and properties in the River Glen and River Trace subdivisions."},{"stage":42,"statement":"Low lying areas along the river around Pennington Bend are inundated from near the River Trace subdivision to the Cumberland River Greenway bridge in Shelby Bottoms Park."}]},"images":{"probability":{"weekint":{"stage":"","flow":"","volume":""},"entperiod":{"stage":"","flow":"","volume":""},"shortrange":""},"hydrograph":{"default":"https://water.noaa.gov/resources/hydrographs/pnbt1_hg.png","floodcat":"https://water.noaa.gov/resources/hydrographs/pnbt1_record.png"},"photos":[]},"dataAttribution":[{"abbrev":"US Geological Survey","text":"USGS--Water Resources of the United States","title":"US Geological Survey","url":"https://waterdata.usgs.gov/nwis"},{"abbrev":"USGS","text":"03430320","title":"Observations courtesy of U.S. Geological Survey","url":"https://waterdata.usgs.gov/nwis/inventory/?site_no=03430320"}],"impactsLowWaters":[],"normalThreshold":{"value":0,"units":"ft"},"hydronotes":[],"datums":{"vertical":{"value":[{"label":"North American Vertical Datum of 1988","abbrev":"NAVD88","description":"A fixed reference for elevations determined by geodetic leveling. The datum was derived from a general adjustment of the first-order terrestrial leveling nets of the United States, Canada, and Mexico. In the adjustment, only the height of the primary tidal bench mark, referenced to the International Great Lakes Datum of 1985 (IGLD 85) local mean sea level height value, at Father Point, Rimouski, Quebec, Canada was held fixed, thus providing minimum constraint. NAVD 88 and IGLD 85 are identical. However, NAVD 88 bench mark values are given in Helmert orthometric height units while IGLD 85 values are in dynamic heights. See International Great Lakes Datum of 1985, National Geodetic Vertical Datum of 1929, and geopotential difference. NAVD 88 should not be used as Mean Sea Level.","value":363.7}]},"horizontal":{"value":[]},"notes":{"value":[]}},"inundation":{"enabled":false,"url":"","zeroDatum":null,"downloads":null,"siteSpecificInfo":"","dataAttribution":[]},"upstreamLid":"HTGT1","downstreamLid":"OMOT1","inService":{"enabled":true,"message":""},"lowThreshold":null,"forecastReliability":"Forecasts are not available. Only observed stages are available for this point.","TruncateObs":"-1","TruncateFcst":"5","ObservedFloodCategory":"obs_not_current","ForecastFloodCategory":"fcst_not_current"},"stageflow":{"observed":{"pedts":"","issuedTime":"0001-01-01T00:00:00Z","wfo":"","timeZone":"","primaryName":"","primaryUnits":"","secondaryName":"","secondaryUnits":"","data":[]},"forecast":{"pedts":"","issuedTime":"0001-01-01T00:00:00Z","wfo":"","timeZone":"","primaryName":"","primaryUnits":"","secondaryName":"","secondaryUnits":"","data":[]}},"modelGuidance":{"analysisAssimilation":{"referenceTime":"2026-05-01T09:00:00Z","units":"ft³/s","data":[{"validTime":"2026-04-27T23:00:00Z","flow":6276.830078125},{"validTime":"2026-04-28T00:00:00Z","flow":6274.7099609375},{"validTime":"2026-04-28T01:00:00Z","flow":6278.94970703125},{"validTime":"2026-04-28T02:00:00Z","flow":6304.02001953125},{"validTime":"2026-04-28T03:00:00Z","flow":6365.11962890625},{"validTime":"2026-04-28T04:00:00Z","flow":6465.759765625},{"validTime":"2026-04-28T05:00:00Z","flow":6596.77978515625},{"validTime":"2026-04-28T06:00:00Z","flow":6739.099609375},{"validTime":"2026-04-28T07:00:00Z","flow":6878.58984375},{"validTime":"2026-04-28T08:00:00Z","flow":7007.83984375},{"validTime":"2026-04-28T09:00:00Z","flow":7112.02001953125},{"val